<Window x:Class="Bo_Tron_Khi_CS.MfcCalibWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MFC Calibration - Kofloc 3660" 
        Height="500" Width="640"
        Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextPriBrush}"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPriBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Height" Value="24"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPriBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource PanelBrush}" CornerRadius="6" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Device Info Header -->
                    <RowDefinition Height="*"/>    <!-- Config Grid -->
                    <RowDefinition Height="Auto"/> <!-- Note -->
                    <RowDefinition Height="Auto"/> <!-- Actions -->
                </Grid.RowDefinitions>

                <!-- Device Info Header -->
                <Border Grid.Row="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="KOFLOC 3660 — Mass Flow Controller" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Control Signal: 0 – 5 VDC (0 – 5000 mV)  |  Range: 2 – 100% F.S.  |  Accuracy: ±1.0% F.S.  |  Repeatability: ±0.5% F.S." FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Config Grid -->
                <Grid Grid.Row="1" Margin="5,5,5,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>  <!-- CH -->
                        <ColumnDefinition Width="180"/> <!-- Channel name -->
                        <ColumnDefinition Width="*"/>   <!-- Min (mV) -->
                        <ColumnDefinition Width="*"/>   <!-- Max (mV) -->
                        <ColumnDefinition Width="*"/>   <!-- Factor -->
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/> <!-- Header -->
                        <RowDefinition Height="30"/> <!-- MFC 1 -->
                        <RowDefinition Height="30"/> <!-- MFC 2 -->
                        <RowDefinition Height="30"/> <!-- MFC 3 -->
                        <RowDefinition Height="30"/> <!-- MFC 4 -->
                        <RowDefinition Height="30"/> <!-- MFC 5 -->
                        <RowDefinition Height="30"/> <!-- MFC 6 -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CH" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="MFC Channel" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" FontSize="12" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Min (mV)" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Max (mV)" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Factor" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- MFC 1 Row -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="1" FontWeight="Bold" Foreground="#38BDF8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="MFC1 — Carrier (Air/N₂)" FontWeight="Bold" Foreground="{DynamicResource TextPriBrush}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMinV_1" Grid.Row="1" Grid.Column="2" Text="0" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtMaxV_1" Grid.Row="1" Grid.Column="3" Text="5000" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtFactor_1" Grid.Row="1" Grid.Column="4" Text="1" Width="75" Margin="2"/>

                    <!-- MFC 2 Row -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="2" FontWeight="Bold" Foreground="#818CF8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="MFC2 — Diluent (Air/N₂)" FontWeight="Bold" Foreground="{DynamicResource TextPriBrush}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMinV_2" Grid.Row="2" Grid.Column="2" Text="0" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtMaxV_2" Grid.Row="2" Grid.Column="3" Text="5000" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtFactor_2" Grid.Row="2" Grid.Column="4" Text="1" Width="75" Margin="2"/>

                    <!-- MFC 3 Row -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="3" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="MFC3 — Gas1 Low Range" FontWeight="Bold" Foreground="{DynamicResource TextPriBrush}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMinV_3" Grid.Row="3" Grid.Column="2" Text="0" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtMaxV_3" Grid.Row="3" Grid.Column="3" Text="5000" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtFactor_3" Grid.Row="3" Grid.Column="4" Text="1" Width="75" Margin="2"/>

                    <!-- MFC 4 Row -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="4" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="MFC4 — Gas1 High Range" FontWeight="Bold" Foreground="{DynamicResource TextPriBrush}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMinV_4" Grid.Row="4" Grid.Column="2" Text="0" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtMaxV_4" Grid.Row="4" Grid.Column="3" Text="5000" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtFactor_4" Grid.Row="4" Grid.Column="4" Text="1" Width="75" Margin="2"/>

                    <!-- MFC 5 Row -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="5" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="MFC5 — Gas2" FontWeight="Bold" Foreground="{DynamicResource TextPriBrush}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMinV_5" Grid.Row="5" Grid.Column="2" Text="0" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtMaxV_5" Grid.Row="5" Grid.Column="3" Text="5000" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtFactor_5" Grid.Row="5" Grid.Column="4" Text="1" Width="75" Margin="2"/>

                    <!-- MFC 6 Row -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="6" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="MFC6 — Gas3" FontWeight="Bold" Foreground="{DynamicResource TextPriBrush}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMinV_6" Grid.Row="6" Grid.Column="2" Text="0" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtMaxV_6" Grid.Row="6" Grid.Column="3" Text="5000" Width="90" Margin="2"/>
                    <TextBox x:Name="TxtFactor_6" Grid.Row="6" Grid.Column="4" Text="1" Width="75" Margin="2"/>
                </Grid>

                <!-- Note -->
                <TextBlock Grid.Row="2" Text="Kofloc 3660: 0 mV = fully closed | 5000 mV (5V) = 100% F.S. open | Useful operating range: 100 mV (2%) to 5000 mV" FontSize="11" FontStyle="Italic" FontWeight="Bold" Foreground="{DynamicResource WarnBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,5"/>

                <!-- Actions -->
                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Save" Click="OnSaveClick" Width="80" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Margin="0,0,8,0"/>
                        <Button Content="Reset Defaults" Click="OnResetDefaultsClick" Width="130" Margin="0,0,8,0"/>
                        <Button Content="Sync to HMI" Click="OnSyncHmiClick" Width="120" Background="#10B981" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                    <Button Content="Close" Click="OnCloseClick" Width="85" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
