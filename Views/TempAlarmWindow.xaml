<Window x:Class="Bo_Tron_Khi_CS.TempAlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chamber Overheat Protection" 
        Height="280" Width="380"
        Background="{DynamicResource PanelBrush}" Foreground="{DynamicResource TextPriBrush}"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPriBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="25"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="*"/>    <!-- Controls -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Temperature Safety Limits" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPriBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Margin="10,0">
            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Alarm Temperature Threshold (°C):" Foreground="{DynamicResource TextSecBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtLimit" Grid.Column="1" Text="50.0" Width="90" HorizontalAlignment="Right"/>
            </Grid>

            <CheckBox x:Name="ChkBeep" Content="Enable audible alarm (Winsound)" Foreground="{DynamicResource TextPriBrush}" FontWeight="Bold" Margin="0,8"/>
            <CheckBox x:Name="ChkStop" Content="Auto emergency valve shutdown on overheat" Foreground="{DynamicResource TextPriBrush}" FontWeight="Bold" Margin="0,8"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save Configuration" Click="OnSaveClick" Width="130" Margin="0,0,8,0"/>
            <Button Content="Cancel" Click="OnCancelClick" Style="{StaticResource SecondaryButton}" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
