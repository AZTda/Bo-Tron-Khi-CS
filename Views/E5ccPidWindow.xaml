<Window x:Class="Bo_Tron_Khi_CS.E5ccPidWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Omron E5CC PID &amp; Advanced Controls" 
        Height="400" Width="480"
        Background="#1E293B" Foreground="#F8FAFC"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="28"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="*"/>    <!-- Params Forms -->
            <RowDefinition Height="Auto"/> <!-- Actions -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="TEMPERATURE CONTROLLER TUNING (E5CC Slave 1)" FontSize="12" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,10"/>

        <TabControl Grid.Row="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1">
            <!-- PID & AT Tab -->
            <TabItem Header="PID &amp; Auto-Tune">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="PID Coefficients" BorderBrush="#334155" Foreground="#94A3B8" Padding="10" Grid.Row="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="4">
                                <TextBlock Text="P (Prop Band):" Foreground="#94A3B8" FontSize="11" Margin="0,0,0,2"/>
                                <TextBox x:Name="TxtP" Text="10.0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4">
                                <TextBlock Text="I (Integral s):" Foreground="#94A3B8" FontSize="11" Margin="0,0,0,2"/>
                                <TextBox x:Name="TxtI" Text="240"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="4">
                                <TextBlock Text="D (Deriv s):" Foreground="#94A3B8" FontSize="11" Margin="0,0,0,2"/>
                                <TextBox x:Name="TxtD" Text="40.0"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Auto-Tune (AT) Control" BorderBrush="#334155" Foreground="#94A3B8" Padding="10" Grid.Row="1" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button x:Name="BtnStartAt" Content="▶ Start Auto-Tune" Click="OnStartAtClick" Width="130" Background="#10B981" Margin="0,0,10,0"/>
                            <Button x:Name="BtnStopAt" Content="⏹ Stop Auto-Tune" Click="OnStopAtClick" Width="130" Background="#DC2626"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Advanced Config Limits -->
            <TabItem Header="Limits &amp; Shifts">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="SP Lower Limit (°C):" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtSpMin" Grid.Row="0" Grid.Column="1" Text="0.0"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="SP Upper Limit (°C):" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtSpMax" Grid.Row="1" Grid.Column="1" Text="300.0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="MV Lower Limit (%):" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMvMin" Grid.Row="2" Grid.Column="1" Text="0.0"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="MV Upper Limit (%):" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMvMax" Grid.Row="3" Grid.Column="1" Text="100.0"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Input Shift Offset (°C):" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtInputShift" Grid.Row="4" Grid.Column="1" Text="0.0"/>
                </Grid>
            </TabItem>

            <!-- Alarms Config -->
            <TabItem Header="Alarms &amp; Cycle">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Alarm 1 Threshold (°C):" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtAlm1" Grid.Row="0" Grid.Column="1" Text="50.0"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Alarm 2 Threshold (°C):" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtAlm2" Grid.Row="1" Grid.Column="1" Text="50.0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Control Period (s):" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtCtrlPeriod" Grid.Row="2" Grid.Column="1" Text="12"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Read / Write Options -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Button x:Name="BtnRead" Content="📥 Read from Controller" Click="OnReadClick" Width="160" HorizontalAlignment="Left" Style="{StaticResource SecondaryButton}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾 Write Settings" Click="OnWriteClick" Width="130" Margin="0,0,8,0"/>
                <Button Content="Close" Click="OnCloseClick" Width="80" Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
