<Window x:Class="Bo_Tron_Khi_CS.MfcSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MFC Setting" 
        Height="420" Width="380"
        Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextPriBrush}"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPriBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Height" Value="24"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPriBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource PanelBrush}" CornerRadius="6" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Configuration inputs -->
                <Grid Grid.Row="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>

                    <!-- Row 1: MFC 1 Range -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="MFC 1 Range:" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPriBrush}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMfc1Range" Grid.Row="0" Grid.Column="1" Text="500" Width="120" HorizontalAlignment="Right"/>

                    <!-- Row 2: MFC 2 Range -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="MFC 2 Range:" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPriBrush}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMfc2Range" Grid.Row="1" Grid.Column="1" Text="500" Width="120" HorizontalAlignment="Right"/>

                    <!-- Row 3: MFC 3 Range -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="MFC 3 Range:" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPriBrush}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMfc3Range" Grid.Row="2" Grid.Column="1" Text="100" Width="120" HorizontalAlignment="Right"/>

                    <!-- Row 4: MFC 4 Range -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="MFC 4 Range:" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPriBrush}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMfc4Range" Grid.Row="3" Grid.Column="1" Text="500" Width="120" HorizontalAlignment="Right"/>

                    <!-- Row 5: MFC 5 Range -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="MFC 5 Range:" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPriBrush}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMfc5Range" Grid.Row="4" Grid.Column="1" Text="100" Width="120" HorizontalAlignment="Right"/>

                    <!-- Row 6: MFC 6 Range -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="MFC 6 Range:" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPriBrush}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMfc6Range" Grid.Row="5" Grid.Column="1" Text="100" Width="120" HorizontalAlignment="Right"/>

                    <!-- Separator -->
                    <Border Grid.Row="6" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center" Margin="0,4"/>

                    <!-- Row 7: U Limit Percent -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="U Limit Percent:" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPriBrush}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtULimit" Grid.Row="6" Grid.Column="1" Text="98" Width="120" HorizontalAlignment="Right"/>

                    <!-- Row 8: L Limit Percent -->
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="L Limit Percent:" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPriBrush}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtLLimit" Grid.Row="7" Grid.Column="1" Text="2" Width="120" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Action buttons -->
                <Grid Grid.Row="1" Margin="0,15,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="💾 Save" Click="OnSaveClick" Width="80" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Margin="0,0,8,0"/>
                        <Button Content="🔄 Sync to HMI" Click="OnSyncHmiClick" Width="120" Background="#10B981" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                    <Button Content="❌ Close" Click="OnCloseClick" Width="80" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
