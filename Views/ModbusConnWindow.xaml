<Window x:Class="Bo_Tron_Khi_CS.ModbusConnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modbus Connection Settings" 
        Height="420" Width="420"
        Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextPriBrush}"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="15">
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource PanelBrush}" CornerRadius="6" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Controls Grid -->
                    <RowDefinition Height="Auto"/> <!-- Buttons -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="MODBUS INTERFACE CONFIGURATION" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,12"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                    </Grid.RowDefinitions>

                    <!-- Port / Connection Type -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Serial Port / Sim:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CbPorts" Grid.Row="0" Grid.Column="1" Height="26" Margin="0,2"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Baud Rate:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CbBaud" Grid.Row="1" Grid.Column="1" Height="26" Margin="0,2">
                        <ComboBoxItem Content="9600"/>
                        <ComboBoxItem Content="19200" IsSelected="True"/>
                        <ComboBoxItem Content="38400"/>
                        <ComboBoxItem Content="115200"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Parity:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CbParity" Grid.Row="2" Grid.Column="1" Height="26" Margin="0,2">
                        <ComboBoxItem Content="Even (E)" IsSelected="True"/>
                        <ComboBoxItem Content="Odd (O)"/>
                        <ComboBoxItem Content="None (N)"/>
                    </ComboBox>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Timeout (seconds):" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtTimeout" Grid.Row="3" Grid.Column="1" Text="0.5" Margin="0,2" Height="24" VerticalContentAlignment="Center" Padding="4,2"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Mixing Board Slave ID:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtMixingSlave" Grid.Row="4" Grid.Column="1" Text="2" Margin="0,2" Height="24" VerticalContentAlignment="Center" Padding="4,2"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Omron E5CC Slave ID:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtE5ccSlave" Grid.Row="5" Grid.Column="1" Text="1" Margin="0,2" Height="24" VerticalContentAlignment="Center" Padding="4,2"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Use TCP connection:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <CheckBox x:Name="ChkUseTcp" Grid.Row="6" Grid.Column="1" VerticalAlignment="Center" Content="Enable TCP (Modbus TCP)" Checked="OnUseTcpChanged" Unchecked="OnUseTcpChanged" Foreground="{DynamicResource TextPriBrush}"/>
                    
                    <!-- TCP Configuration -->
                    <TextBlock x:Name="LblTcpIp" Grid.Row="7" Grid.Column="0" Text="TCP IP Address:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtTcpIp" Grid.Row="7" Grid.Column="1" Text="127.0.0.1" Margin="0,2" Height="24" VerticalContentAlignment="Center" Padding="4,2"/>

                    <TextBlock x:Name="LblTcpPort" Grid.Row="8" Grid.Column="0" Text="TCP Port:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtTcpPort" Grid.Row="8" Grid.Column="1" Text="502" Margin="0,2" Height="24" VerticalContentAlignment="Center" Padding="4,2"/>
                </Grid>

                <!-- Save / Cancel -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Save Settings" Click="OnSaveClick" Width="110" Margin="0,0,8,0" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Height="28"/>
                    <Button Content="Cancel" Click="OnCancelClick" Width="80" Height="28"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
