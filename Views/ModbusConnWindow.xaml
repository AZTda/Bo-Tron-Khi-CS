<Window x:Class="Bo_Tron_Khi_CS.ModbusConnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection Settings" 
        Height="190" Width="360"
        Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextPriBrush}"
        FontFamily="Segoe UI, Arial"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="15">
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource PanelBrush}" CornerRadius="6" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Control -->
                    <RowDefinition Height="Auto"/> <!-- Buttons -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="SELECT CONNECTION PORT" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,12"/>

                <Grid Grid.Row="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Serial Port:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CbPorts" Grid.Column="1" Height="28" VerticalContentAlignment="Center" DropDownOpened="CbPorts_DropDownOpened"/>
                </Grid>

                <!-- Save / Cancel -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Save" Click="OnSaveClick" Width="80" Margin="0,0,8,0" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Height="28"/>
                    <Button Content="Cancel" Click="OnCancelClick" Width="80" Height="28"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
